{
  "title": "Performance Constraints",
  "philosophy": "Fast is a feature. Performance is not optional—it's a core design requirement.",
  "bundleSize": {
    "title": "Bundle Size Limits",
    "rule": "Every kilobyte counts. Measure, optimize, measure again.",
    "limits": [
      { "asset": "JavaScript", "maxSize": "200KB", "format": "gzipped", "severity": "Critical" },
      { "asset": "CSS", "maxSize": "50KB", "format": "gzipped", "severity": "Critical" },
      { "asset": "Total Initial Bundle", "maxSize": "1MB", "format": "uncompressed", "severity": "Critical" }
    ],
    "coreWebVitals": [
      { "metric": "TTI", "target": "< 3.5s", "condition": "4G connection", "description": "Time to Interactive" },
      { "metric": "FCP", "target": "< 1.5s", "condition": "4G connection", "description": "First Contentful Paint" },
      { "metric": "LCP", "target": "< 2.5s", "condition": "4G connection", "description": "Largest Contentful Paint" }
    ],
    "monitoring": [
      "Run bundle analyzer before major releases",
      "Set up performance budgets in CI",
      "Track Core Web Vitals in production"
    ],
    "codeSplitting": {
      "strategies": [
        { "priority": 1, "strategy": "Route-based", "description": "Split by route/page", "candidates": "All page components" },
        { "priority": 2, "strategy": "Component-based", "description": "Split large components not immediately visible", "candidates": "Modals, dialogs, charts, rich text editors, large data tables" },
        { "priority": 3, "strategy": "Vendor-based", "description": "Separate third-party code", "candidates": "External libraries" }
      ],
      "loadingExample": "<Suspense fallback={<Skeleton />}>\n  <LazyComponent />\n</Suspense>",
      "violations": [
        "No code splitting (single bundle)",
        "Missing Suspense boundaries",
        "Lazy loading critical above-fold content",
        "No loading states during chunk loads"
      ]
    },
    "tooling": {
      "bundleAnalysis": ["webpack-bundle-analyzer", "vite-bundle-visualizer", "source-map-explorer"],
      "performanceTesting": ["Lighthouse", "WebPageTest", "Browser DevTools Performance tab"],
      "monitoring": ["Core Web Vitals", "Real User Monitoring (RUM)", "Performance monitoring services"]
    }
  },
  "loadTime": {
    "title": "Load Time Optimization",
    "targets": {
      "TTI": "< 3.5s",
      "FCP": "< 1.5s",
      "LCP": "< 2.5s"
    },
    "codeSplitting": {
      "rule": "Split code to load only what's needed, when it's needed.",
      "strategies": [
        { "priority": 1, "strategy": "Route-based", "description": "Split by route/page" },
        { "priority": 2, "strategy": "Component-based", "description": "Split large components not immediately visible" },
        { "priority": 3, "strategy": "Vendor-based", "description": "Separate third-party code" }
      ]
    },
    "suspensePattern": {
      "rule": "Always provide loading states for lazy-loaded components",
      "example": "<Suspense fallback={<Skeleton />}>\n  <LazyComponent />\n</Suspense>"
    },
    "violations": [
      "No code splitting (single bundle)",
      "Missing Suspense boundaries",
      "Lazy loading critical above-fold content",
      "No loading states during chunk loads"
    ]
  },
  "animation": {
    "title": "Animation Performance",
    "rule": "Animations must not cause jank. 60fps or nothing.",
    "targets": {
      "frameRate": "60fps",
      "frameBudget": "16.67ms per frame"
    },
    "allowedProperties": [
      { "property": "transform", "safe": true, "reason": "GPU-accelerated, no layout/paint" },
      { "property": "opacity", "safe": true, "reason": "GPU-accelerated, no layout/paint" },
      { "property": "width, height", "safe": false, "reason": "Triggers layout recalculation" },
      { "property": "top, left, right, bottom", "safe": false, "reason": "Triggers layout recalculation" },
      { "property": "margin, padding", "safe": false, "reason": "Triggers layout recalculation" }
    ],
    "safeExamples": [
      "transform: translateX(100px);",
      "transform: scale(1.1);",
      "transform: rotate(45deg);",
      "opacity: 0.5;"
    ],
    "durationLimits": [
      { "type": "UI Feedback", "maxDuration": "300ms", "useCase": "Button clicks, hover states, micro-interactions" },
      { "type": "Transitions", "maxDuration": "500ms", "useCase": "Page transitions, modal open/close" },
      { "type": "Complex", "maxDuration": "1000ms", "useCase": "Multi-step animations" }
    ],
    "willChange": {
      "rules": [
        "Use sparingly",
        "Remove after animation completes",
        "Creates new compositor layer and uses GPU memory"
      ]
    },
    "reducedMotion": {
      "mediaQuery": "@media (prefers-reduced-motion: reduce) {\n  *, *::before, *::after {\n    animation-duration: 0.01ms !important;\n    transition-duration: 0.01ms !important;\n  }\n}",
      "requirements": [
        "Disable non-essential animations",
        "Replace complex animations with simple fades",
        "Keep functional animations (loading spinners) but simplify",
        "Provide instant state changes instead of transitions"
      ],
      "exceptions": [
        "Loading indicators (simplify, don't remove)",
        "Progress bars (essential feedback)",
        "Focus indicators (accessibility requirement)"
      ],
      "violations": [
        "Ignoring prefers-reduced-motion",
        "Removing all animations including essential feedback",
        "Not testing with reduced motion enabled"
      ]
    },
    "violations": [
      "Animating width/height/top/left",
      "Animations > 300ms for UI feedback",
      "No will-change optimization for complex animations",
      "Animations causing < 60fps on mid-range devices"
    ]
  },
  "images": {
    "title": "Image Optimization",
    "rule": "Images are often the heaviest assets. Optimize aggressively.",
    "formatSelection": {
      "preferred": "WebP",
      "fallback": "JPEG for photos, PNG for transparency",
      "avoid": "BMP, TIFF, uncompressed formats"
    },
    "loadingStrategy": [
      { "type": "Below-fold images", "strategy": "loading=\"lazy\"" },
      { "type": "Above-fold critical images", "strategy": "loading=\"eager\"" }
    ],
    "qualitySettings": {
      "maximum": "85%",
      "rationale": "Beyond 85%, file size increases dramatically with minimal visual improvement",
      "recommended": "75-85%"
    },
    "responsiveImages": {
      "breakpoints": ["320w", "640w", "1024w", "1920w"],
      "example": "<img\n  srcset=\"image-320.webp 320w, image-640.webp 640w, image-1024.webp 1024w\"\n  sizes=\"(max-width: 640px) 100vw, 50vw\"\n  alt=\"Description\"\n/>"
    },
    "violations": [
      "Serving unoptimized images",
      "Missing srcset for responsive images",
      "Eager loading below-fold images",
      "Using PNG for photographs",
      "Quality > 85% without justification"
    ],
    "checklist": [
      "WebP format",
      "loading=\"lazy\" for below-fold",
      "srcset for responsive",
      "Quality ≤ 85%"
    ]
  },
  "responseTime": {
    "title": "Response Time Thresholds",
    "rule": "Users perceive delays. Provide appropriate feedback at each threshold.",
    "thresholds": [
      { "duration": "< 100ms", "perception": "Instant", "requiredFeedback": "None needed" },
      { "duration": "100-400ms", "perception": "Slight delay", "requiredFeedback": "Subtle indicator (disable button, cursor change)" },
      { "duration": "> 400ms", "perception": "Noticeable wait", "requiredFeedback": "Spinner or skeleton" },
      { "duration": "> 1s", "perception": "Long operation", "requiredFeedback": "Progress indicator with percentage" },
      { "duration": "> 10s", "perception": "Extended operation", "requiredFeedback": "Progress bar, status messages, cancel button" }
    ],
    "dohertyThreshold": {
      "target": "400ms",
      "description": "Response times under 400ms feel instant and keep users in flow state. This is the target for all interactive operations."
    },
    "violations": [
      "No loading state for operations > 400ms",
      "No progress indicator for operations > 1s",
      "No cancel option for operations > 10s",
      "Blocking UI without feedback"
    ]
  },
  "quickReference": {
    "criticalLimits": [
      { "constraint": "JS Bundle", "limit": "< 200KB gzipped" },
      { "constraint": "CSS Bundle", "limit": "< 50KB gzipped" },
      { "constraint": "TTI", "limit": "< 3.5s" },
      { "constraint": "FCP", "limit": "< 1.5s" },
      { "constraint": "LCP", "limit": "< 2.5s" },
      { "constraint": "Animation Frame Rate", "limit": "60fps" },
      { "constraint": "UI Feedback Duration", "limit": "< 300ms" },
      { "constraint": "Doherty Threshold", "limit": "400ms" },
      { "constraint": "Image Quality", "limit": "75-85%" }
    ],
    "animateSafe": ["transform", "opacity"],
    "animateUnsafe": ["width", "height", "top", "left", "right", "bottom", "margin", "padding"],
    "loadingFeedbackByDuration": [
      { "duration": "< 100ms", "action": "Nothing" },
      { "duration": "100-400ms", "action": "Disable controls" },
      { "duration": "> 400ms", "action": "Show spinner" },
      { "duration": "> 1s", "action": "Show progress" },
      { "duration": "> 10s", "action": "Add cancel option" }
    ],
    "preReleaseChecklist": [
      "Bundle size within limits",
      "Code splitting implemented",
      "Images optimized",
      "Animations use transform/opacity only",
      "Reduced motion supported",
      "Loading states for all async operations",
      "Core Web Vitals passing"
    ]
  }
}
