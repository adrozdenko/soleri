{
  "philosophy": {
    "name": "Wu Wei (Effortless Action)",
    "principle": "Work WITH the system, not against it.",
    "description": "The principle of Wu Wei emphasizes creating components that flow naturally within the existing architecture. Every component should feel like it belongs, requiring minimal force to integrate and maintain."
  },
  "preBuild": {
    "title": "Pre-Build Checklist",
    "description": "Before writing any code, answer these questions",
    "gate": {
      "questions": [
        {
          "question": "Does an existing component solve this?",
          "ifYes": "Use it. Stop.",
          "ifNo": "Continue"
        },
        {
          "question": "Is there a real use case (design/ticket)?",
          "ifYes": "Continue",
          "ifNo": "Don't build"
        },
        {
          "question": "Will this break existing consumers?",
          "ifYes": "STOP. Deprecate instead.",
          "ifNo": "Continue"
        },
        {
          "question": "Am I adding more than 3 props?",
          "ifYes": "Step back. Simplify.",
          "ifNo": "Continue"
        }
      ]
    },
    "quickReference": {
      "title": "The 4-Question Pre-Build Gate",
      "steps": [
        "Existing solution? -> Use it",
        "Real use case? -> Required",
        "Breaking change? -> Deprecate instead",
        "More than 3 props? -> Simplify"
      ]
    }
  },
  "duplicateDetection": {
    "title": "Duplicate Detection",
    "mandatory": true,
    "description": "Duplicate detection is mandatory before creating any new component.",
    "searchTerms": {
      "button": ["button", "btn", "action", "trigger", "cta", "submit"],
      "card": ["card", "tile", "panel", "box", "container", "surface"],
      "input": ["input", "field", "textbox", "entry", "form-control"],
      "modal": ["modal", "dialog", "popup", "overlay", "sheet", "drawer"],
      "list": ["list", "table", "grid", "collection", "items"],
      "menu": ["menu", "dropdown", "select", "picker", "combobox"],
      "badge": ["badge", "tag", "chip", "pill", "label", "status"],
      "alert": ["alert", "toast", "notification", "banner", "message"],
      "empty": ["empty", "placeholder", "no-data", "blank", "zero-state"],
      "loading": ["loading", "spinner", "skeleton", "progress", "pending"]
    },
    "steps": [
      {
        "step": 1,
        "title": "Search for Similar Components",
        "action": "Search your codebase for existing implementations using common naming patterns"
      },
      {
        "step": 2,
        "title": "Check Component Registry",
        "action": "Review your component registry or documentation for existing components"
      },
      {
        "step": 3,
        "title": "Check Stories/Documentation",
        "action": "Search for existing story files or component documentation"
      },
      {
        "step": 4,
        "title": "Document Decision",
        "action": "Record the match result and action taken"
      }
    ],
    "matchResults": [
      {
        "result": "Exact match found",
        "action": "Use existing component. STOP."
      },
      {
        "result": "80%+ similar match",
        "action": "Extend existing with variant/prop"
      },
      {
        "result": "Similar pattern exists",
        "action": "Discuss - compose or extract shared primitive"
      },
      {
        "result": "No match found",
        "action": "Proceed with new component"
      }
    ]
  },
  "apiDesign": {
    "title": "API Design Principles",
    "props": {
      "do": [
        "Minimal props that solve real use cases",
        "Use `variant` enum for visual styles",
        "Composition over configuration",
        "Children for flexible content"
      ],
      "dont": [
        "Props \"just in case\"",
        "Boolean props that combine",
        "Mega-components with 10+ props",
        "Multiple slot props (leftIcon, rightIcon, prefix, suffix)"
      ]
    },
    "variants": {
      "do": [
        "3-5 variants that exist in designs",
        "Semantic names (primary, destructive)",
        "Single variant prop"
      ],
      "dont": [
        "Every possible variation",
        "Generic names (type1, type2)",
        "Multiple boolean flags"
      ]
    },
    "sizes": {
      "do": [
        "sm, md, lg (3 sizes)",
        "Size only if designs require it",
        "Consistent scale across components"
      ],
      "dont": [
        "xs, sm, md, lg, xl, 2xl",
        "Size prop on every component",
        "Different size scales per component"
      ]
    },
    "compositionPriority": "Children > Slots > Props > Configuration Objects",
    "the333Rule": {
      "title": "The 3-3-3 Rule",
      "rules": [
        "3 sizes max: sm, md, lg",
        "3-5 variants: Only what designs require",
        "3 props or less: Per feature addition"
      ]
    }
  },
  "implementation": {
    "title": "Implementation Guidelines",
    "tokenUsage": {
      "do": [
        "Semantic tokens (bg-surface, text-primary)",
        "Design system spacing (gap-4, p-6)",
        "Standard radius/shadow (rounded-md, shadow-md)"
      ],
      "dont": [
        "Hardcoded values (bg-white, text-gray-900)",
        "Arbitrary values (gap-[18px], padding: 23px)",
        "Magic numbers (rounded-[12px])"
      ]
    },
    "stylingPatterns": {
      "do": [
        "Variant utilities (cva or similar)",
        "Class merging utilities",
        "Utility-first CSS"
      ],
      "dont": [
        "Ternary chains",
        "String concatenation",
        "CSS-in-JS or CSS modules for variants"
      ]
    },
    "primitives": {
      "description": "Use established primitive libraries for complex interactive components",
      "recommended": [
        "Dialog/Modal",
        "Select/Combobox",
        "Tabs",
        "Tooltip",
        "Accordion",
        "Checkbox/Radio"
      ]
    }
  },
  "compatibility": {
    "title": "Backwards Compatibility",
    "safeChanges": {
      "title": "Safe Changes (Non-Breaking)",
      "changes": [
        "Add optional prop with sensible default",
        "Add new variant to existing prop",
        "Add new component",
        "Bug fixes",
        "Performance improvements"
      ]
    },
    "breakingChanges": {
      "title": "Breaking Changes (Require Migration)",
      "changes": [
        "Rename prop",
        "Remove prop",
        "Change prop type",
        "Change default value",
        "Remove export"
      ]
    },
    "migrationPattern": {
      "title": "Migration Pattern",
      "description": "When breaking changes are necessary",
      "steps": [
        "Add `@deprecated` documentation to old API",
        "Support both old and new API during transition",
        "Log console warnings for deprecated usage",
        "Remove deprecated API in next major version"
      ]
    }
  },
  "redFlags": {
    "title": "Red Flags",
    "description": "Watch for these warning signs during development",
    "signals": [
      {
        "signal": "Adding 5+ props at once",
        "action": "Split into multiple components"
      },
      {
        "signal": "Complex conditional rendering",
        "action": "Extract sub-components"
      },
      {
        "signal": "Inline styles appearing",
        "action": "Use design tokens"
      },
      {
        "signal": "Copy-pasting from another component",
        "action": "Extract shared primitive"
      },
      {
        "signal": "\"Just in case\" additions",
        "action": "Remove. Add when actually needed."
      },
      {
        "signal": "Fighting the type system",
        "action": "Design is wrong. Rethink approach."
      }
    ]
  },
  "gotchas": {
    "title": "Common Gotchas",
    "svgIconColors": {
      "title": "SVG Icon Colors",
      "problem": "Never rely on `currentColor` for SVG icons in hover states.",
      "explanation": "SVG elements create new stacking contexts, and `currentColor` resolves at the SVG level, not the parent level.",
      "wrong": "text-error hover:text-white",
      "correct": "text-error hover:text-white hover:[&_svg]:[stroke:white]"
    },
    "darkBackgroundContrast": {
      "title": "Dark Background Contrast",
      "problem": "Always verify contrast BEFORE using dark backgrounds.",
      "workflow": [
        "Choose background color",
        "Verify contrast programmatically",
        "Choose text color",
        "Verify contrast again",
        "Build component"
      ],
      "rule": "Never use the same color palette for both background AND text (e.g., primary-700 background with primary-100 text often fails).",
      "safeTextColors": [
        "White",
        "Very light neutrals (50-200 range)",
        "Accent colors from different palette"
      ]
    }
  },
  "checklist": {
    "title": "Component Checklist",
    "description": "Before marking a component complete, verify",
    "requirements": [
      {
        "requirement": "Types",
        "validation": "Full TypeScript coverage, types exported"
      },
      {
        "requirement": "Tokens",
        "validation": "Zero hardcoded colors or spacing"
      },
      {
        "requirement": "Contrast",
        "validation": "Dark backgrounds verified for accessibility"
      },
      {
        "requirement": "Accessibility",
        "validation": "Proper ARIA attributes or primitive library"
      },
      {
        "requirement": "Variants",
        "validation": "Consistent variant pattern used"
      },
      {
        "requirement": "Export",
        "validation": "Added to main index/barrel file"
      },
      {
        "requirement": "Documentation",
        "validation": "Story/example covering all variants"
      },
      {
        "requirement": "Registry",
        "validation": "Component registered in documentation"
      }
    ]
  },
  "quickDecisions": {
    "title": "Quick Decisions",
    "decisions": [
      {
        "question": "New component or extend existing?",
        "answer": "Extend if 80%+ similar"
      },
      {
        "question": "Prop or children?",
        "answer": "Children for content, props for behavior"
      },
      {
        "question": "One component or compound?",
        "answer": "Compound if more than 3 subparts"
      },
      {
        "question": "Controlled or uncontrolled?",
        "answer": "Support both patterns"
      },
      {
        "question": "Add size prop?",
        "answer": "Only if designs have multiple sizes"
      }
    ]
  }
}
