{
  "meta": {
    "title": "Dialog Pattern Rules",
    "description": "Choose container patterns based on complexity, not convenience. Decision criteria for selecting between Dialog, Page, Wizard, and Sheet patterns.",
    "corePrinciple": "The right container reduces cognitive load and matches user expectations for the task at hand."
  },
  "fieldCountThresholds": {
    "dialog": { "min": 1, "max": 7, "complexity": "low-medium" },
    "sheet": { "min": 1, "max": 7, "complexity": "low-medium", "note": "contextual" },
    "page": { "min": 8, "max": 12, "complexity": "high" },
    "wizard": { "min": 13, "max": null, "complexity": "very-high" }
  },
  "selectionByFieldCount": [
    {
      "range": "1-3",
      "complexity": "low",
      "recommendedPattern": "dialog",
      "examples": ["Delete confirmation", "Password reset"]
    },
    {
      "range": "4-7",
      "complexity": "medium",
      "recommendedPattern": "dialog or sheet",
      "examples": ["Create account", "Quick settings"]
    },
    {
      "range": "8-12",
      "complexity": "high",
      "recommendedPattern": "page",
      "examples": ["Edit profile", "Invoice forms"]
    },
    {
      "range": "13+",
      "complexity": "very-high",
      "recommendedPattern": "wizard",
      "examples": ["Onboarding", "Multi-step setup"]
    }
  ],
  "decisionTree": {
    "question": "Is it a confirmation or acknowledgment?",
    "yes": "dialog",
    "no": {
      "question": "How many fields?",
      "branches": [
        { "condition": "1-3 fields", "result": "dialog" },
        { "condition": "4-7 fields", "result": "dialog (simple) or sheet (contextual)" },
        { "condition": "8-12 fields", "result": "page" },
        {
          "condition": "13+ fields",
          "question": "Does it have logical steps?",
          "yes": "wizard",
          "no": "page with sections"
        }
      ]
    }
  },
  "patterns": {
    "dialog": {
      "name": "Dialog",
      "useFor": [
        "Confirmations (delete, archive, publish)",
        "Simple forms (1-7 fields)",
        "Password or credential entry",
        "Quick inline creation",
        "Acknowledgments",
        "Tasks user expects to complete in under 30 seconds"
      ],
      "characteristics": {
        "maximumFields": 7,
        "expectedCompletionTime": "< 30 seconds",
        "interruptsCurrentFlow": true,
        "modalPosition": "center"
      },
      "quickReference": {
        "fieldCount": "1-7",
        "time": "< 30s",
        "primaryTask": false
      }
    },
    "page": {
      "name": "Page",
      "useFor": [
        "Complex forms (8+ fields)",
        "Primary CRUD workflows",
        "Data entry with multiple sections",
        "Forms requiring full keyboard navigation",
        "Tasks taking more than 1 minute",
        "Primary (not secondary) workflows"
      ],
      "characteristics": {
        "minimumFields": 8,
        "expectedCompletionTime": "> 1 minute",
        "primaryWorkflow": true,
        "fullFocusMode": true
      },
      "quickReference": {
        "fieldCount": "8-12",
        "time": "> 1min",
        "primaryTask": true
      },
      "implementationApproaches": {
        "routedPages": {
          "description": "Best for complex forms that deserve their own URL and navigation history",
          "examples": [
            "/partners/:id/edit → Edit Partner Page",
            "/invoices/new → Create Invoice Page"
          ]
        },
        "inlinePanel": {
          "description": "Alternative for side-by-side editing patterns where context needs to be preserved",
          "layout": "Data Table + Edit Panel side by side"
        }
      }
    },
    "wizard": {
      "name": "Wizard",
      "useFor": [
        "Multi-step processes (13+ fields)",
        "Onboarding flows",
        "Provisioning and setup tasks",
        "Workflows with natural step divisions",
        "Scenarios requiring progress saving"
      ],
      "characteristics": {
        "minimumFields": 13,
        "hasLogicalSteps": true,
        "progressIndicator": "required",
        "draftSaving": "recommended"
      },
      "quickReference": {
        "fieldCount": "13+",
        "time": "> 2min",
        "primaryTask": true,
        "note": "multi-step"
      }
    },
    "sheet": {
      "name": "Sheet",
      "useFor": [
        "Preview and detail views",
        "Mobile interactions",
        "Filters and quick settings",
        "Contextual information panels",
        "Responsive pattern: Dialog on desktop, Sheet on mobile"
      ],
      "characteristics": {
        "contextualDisplay": true,
        "animation": "slide-in",
        "mobilePreference": "high"
      },
      "quickReference": {
        "fieldCount": "1-7",
        "time": "< 30s",
        "primaryTask": false,
        "note": "contextual"
      }
    }
  },
  "cognitiveLoadPrinciples": {
    "millersLaw": {
      "description": "Working memory holds approximately 7 items. Forms exceeding this threshold risk cognitive overload.",
      "thresholds": [
        {
          "fieldCount": "≤ 5",
          "cognitiveLoad": "low",
          "userExperience": "Scan and complete quickly"
        },
        {
          "fieldCount": "6-9",
          "cognitiveLoad": "medium",
          "userExperience": "Requires focused attention"
        },
        { "fieldCount": "10+", "cognitiveLoad": "high", "userExperience": "Risk of overwhelm" }
      ]
    },
    "modalInterruptionCost": {
      "description": "Dialogs interrupt user flow. This interruption is only justified for quick confirmations, low-complexity actions, and secondary tasks.",
      "justifiedFor": ["Quick confirmations", "Low-complexity actions", "Secondary tasks"],
      "conclusion": "Complex primary workflows deserve full-page focus."
    }
  },
  "antiPatterns": [
    {
      "badPractice": "11-field form in dialog",
      "problem": "Exceeds cognitive capacity",
      "solution": "Use Page"
    },
    {
      "badPractice": "Multi-step wizard in dialog",
      "problem": "Wrong container for complexity",
      "solution": "Use dedicated Wizard"
    },
    {
      "badPractice": "Primary workflow in dialog",
      "problem": "Undervalues importance",
      "solution": "Use Page"
    },
    {
      "badPractice": "Dialog for data entry > 1 minute",
      "problem": "Interruption cost too high",
      "solution": "Use Page"
    }
  ],
  "validPatterns": [
    {
      "pattern": "Delete confirmation in dialog",
      "fieldCount": 0,
      "whyItWorks": "Quick acknowledgment"
    },
    {
      "pattern": "Password reset in dialog",
      "fieldCount": 2,
      "whyItWorks": "Simple, fast completion"
    },
    {
      "pattern": "Quick create in dialog",
      "fieldCount": "3-5",
      "whyItWorks": "Under cognitive threshold"
    }
  ],
  "decisionShortcuts": [
    { "condition": "Confirmation?", "result": "Dialog" },
    { "condition": "Quick setting?", "result": "Sheet" },
    { "condition": "Primary workflow?", "result": "Page" },
    { "condition": "Multiple logical steps?", "result": "Wizard" },
    { "condition": "Mobile-first context?", "result": "Sheet" },
    { "condition": "> 7 fields?", "result": "Page or Wizard" }
  ],
  "cognitiveThresholds": [
    { "threshold": "7 fields", "action": "Maximum for dialogs (Miller's Law)" },
    { "threshold": "30 seconds", "action": "Maximum dialog completion time" },
    { "threshold": "1 minute", "action": "Switch to page-based layout" },
    { "threshold": "13 fields", "action": "Consider wizard with steps" }
  ]
}
