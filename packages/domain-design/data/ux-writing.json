{
  "meta": {
    "title": "UX Writing Guidelines",
    "description": "Clear, consistent, and human-centered copy shapes user experiences",
    "version": "1.0.0"
  },
  "principles": {
    "clarity": {
      "title": "Clarity",
      "rules": [
        {
          "name": "Simple Language",
          "description": "Use words everyone understands. Replace jargon with plain alternatives."
        },
        {
          "name": "Concision",
          "description": "Keep messages short and direct. Remove unnecessary words. Every word should earn its place."
        }
      ]
    },
    "consistency": {
      "title": "Consistency",
      "rules": [
        {
          "name": "Terminology",
          "description": "Use consistent terms across all features. One concept = one word."
        },
        {
          "name": "Formatting",
          "description": "Apply consistent patterns for similar messages (errors, confirmations, empty states)."
        }
      ]
    },
    "accessibility": {
      "title": "Accessibility",
      "rules": [
        {
          "name": "Inclusive Language",
          "description": "Write respectfully for diverse audiences. Use gender-neutral terms."
        },
        {
          "name": "Readability",
          "description": "Write short sentences with familiar words. Aim for an 8th-grade reading level."
        }
      ]
    }
  },
  "voice": {
    "characteristics": [
      {
        "trait": "Empathetic & Conversational",
        "description": "Human to human - speak with users honestly and directly",
        "example": "Looks like this report is taking longer than expected. We're on it - you'll get an email when it's ready."
      },
      {
        "trait": "Positive & Professional",
        "description": "Use affirmative language to motivate users",
        "example": "Great choice! This workflow will save your team about 4 hours per week."
      }
    ],
    "personalityTraits": {
      "expertReliable": ["Knowledgeable", "Confident", "Accountable", "Trustworthy"],
      "proactiveSupportive": ["Helpful", "Anticipatory", "Thoughtful", "Empowering"]
    }
  },
  "tone": {
    "spectrum": [
      {
        "tone": "Light & Engaging",
        "useWhen": "Message is simple and there's opportunity to delight",
        "bestFor": ["New features", "Empty states", "Onboarding", "Success messages"]
      },
      {
        "tone": "Professional & Reliable",
        "useWhen": "Top priority is to reassure users",
        "bestFor": ["Errors", "Payments", "Security", "Legal", "Data handling"]
      }
    ],
    "byContext": {
      "success": {
        "tone": "Celebratory",
        "energy": "High",
        "example": "You did it! Project created."
      },
      "empty": {
        "tone": "Encouraging",
        "energy": "Medium",
        "example": "No items yet. Create your first one?"
      },
      "loading": {
        "tone": "Reassuring",
        "energy": "Low",
        "example": "Getting everything ready..."
      },
      "error": {
        "tone": "Calm & Clear",
        "energy": "Neutral",
        "example": "Something went wrong. Try again."
      },
      "warning": {
        "tone": "Cautious",
        "energy": "Medium",
        "example": "This action cannot be undone."
      },
      "security": {
        "tone": "Serious",
        "energy": "Low",
        "example": "Your session has expired."
      }
    }
  },
  "goldenRules": {
    "values": [
      {
        "rule": "We work for the users",
        "description": "They don't work for us"
      },
      {
        "rule": "Stay consistent",
        "description": "Use consistent terminology"
      },
      {
        "rule": "Keep it stress-free",
        "description": "Never manipulate or guilt users"
      },
      {
        "rule": "Gradual complexity",
        "description": "Introduce features one step at a time"
      },
      {
        "rule": "Kind over clever",
        "description": "Never use passive-aggressive language"
      },
      {
        "rule": "Write for all readers",
        "description": "Clear language without jargon"
      }
    ],
    "practical": [
      {
        "rule": "Bottom line first",
        "description": "Start with most important information"
      },
      {
        "rule": "Give full context",
        "description": "Users know exactly where they are"
      },
      {
        "rule": "User's point of view",
        "description": "Focus on what users want to do"
      },
      {
        "rule": "One CTA",
        "description": "Present only one call-to-action at a time"
      },
      {
        "rule": "Specific CTAs",
        "description": "CTAs respond directly to the header"
      },
      {
        "rule": "Cut the fluff",
        "description": "Write briefly and to the point"
      }
    ]
  },
  "grammar": {
    "capitalization": {
      "rule": "Sentence case for all UI elements",
      "details": "Only capitalize proper nouns and first word"
    },
    "punctuation": {
      "rule": "Periods for complete sentences",
      "details": "No periods for fragments/labels/buttons. Use oxford commas."
    },
    "numbers": {
      "rule": "Spell out one through nine",
      "details": "Use numerals for 10+ and measurements"
    },
    "contractions": {
      "rule": "Use to sound conversational",
      "details": "Avoid in error messages, legal, and security contexts"
    }
  },
  "checklist": {
    "title": "Writing Checklist",
    "description": "Before publishing any UI copy, verify:",
    "items": [
      {
        "check": "Clear",
        "question": "Could a new user understand this?"
      },
      {
        "check": "Concise",
        "question": "Can I remove any words?"
      },
      {
        "check": "Helpful",
        "question": "Does it guide the user forward?"
      },
      {
        "check": "Consistent",
        "question": "Does it match existing patterns?"
      },
      {
        "check": "Kind",
        "question": "Would I want to read this?"
      },
      {
        "check": "Accessible",
        "question": "Is it free of jargon and bias?"
      }
    ]
  },
  "patterns": {
    "buttons": {
      "title": "Buttons & CTAs",
      "do": [
        "Use action verbs: Save, Create, Delete",
        "Be specific: \"Save Changes\" not just \"Save\"",
        "Match button to dialog title",
        "Keep under 3 words"
      ],
      "dont": [
        "Vague labels: OK, Yes, No, Submit",
        "Redundant: \"Click here to save\"",
        "Full sentences",
        "ALL CAPS"
      ],
      "examples": {
        "good": ["Save Changes", "Create Project", "Delete Item"],
        "bad": ["OK", "Click Here to Continue", "Yes, I Want to Delete This Item"]
      },
      "quickGuide": {
        "create": { "good": ["Create", "Add", "New"], "avoid": ["Submit", "OK"] },
        "save": { "good": ["Save", "Save Changes", "Update"], "avoid": ["Done", "Confirm"] },
        "delete": { "good": ["Delete", "Remove"], "avoid": ["Yes", "OK"] },
        "cancel": { "good": ["Cancel", "Go Back"], "avoid": ["No", "Dismiss"] },
        "navigate": { "good": ["View", "Open", "Go to"], "avoid": ["Click here"] }
      }
    },
    "errors": {
      "title": "Error Messages",
      "do": [
        "Explain what happened in plain language",
        "Offer a solution",
        "Take responsibility",
        "Be specific"
      ],
      "dont": ["Blame the user", "Use technical jargon", "Be vague", "Use negative tone"],
      "examples": {
        "good": [
          "We couldn't save your changes. Please try again.",
          "Password must be at least 8 characters with one number."
        ],
        "bad": ["Error: Invalid input", "You failed to complete the form correctly"]
      },
      "replacements": {
        "Invalid": "Check your [field name]",
        "Error occurred": "Something went wrong",
        "Forbidden": "You don't have access",
        "Null/Empty": "No [items] yet"
      }
    },
    "empty-states": {
      "title": "Empty States",
      "do": [
        "Explain why the area is empty",
        "Provide a clear action",
        "Be encouraging",
        "Use illustrations when appropriate"
      ],
      "dont": [
        "Just say \"No data\"",
        "Leave users without guidance",
        "Use technical terms",
        "Make users feel broken"
      ],
      "examples": {
        "good": [
          "No projects yet. Create your first one to get started.",
          "Your inbox is empty. You're all caught up!"
        ],
        "bad": ["No data", "0 records found"]
      }
    },
    "success": {
      "title": "Success Messages",
      "do": [
        "Celebrate the accomplishment",
        "Be specific about what happened",
        "Include next steps",
        "Use positive language"
      ],
      "dont": [
        "Be generic: \"Success\"",
        "Skip important details",
        "Use technical codes",
        "Overwhelm with info"
      ],
      "examples": {
        "good": ["Project created! Ready to add your first task?", "Changes saved successfully."],
        "bad": ["Success", "Transaction ID: 8492840294"]
      }
    },
    "forms": {
      "title": "Form Labels",
      "do": [
        "Sentence case: \"Email address\"",
        "Helpful examples: \"e.g., john@company.com\"",
        "Explain requirements upfront",
        "Use placeholder sparingly"
      ],
      "dont": [
        "Placeholder as only label",
        "ALL CAPS labels",
        "Asterisks without explanation",
        "Repeat label in helper text"
      ],
      "examples": {
        "good": ["Label: \"Email address\" / Helper: \"e.g., john@company.com\""],
        "bad": ["EMAIL ADDRESS *"]
      }
    },
    "loading": {
      "title": "Loading Messages",
      "do": [
        "Tell users what's happening",
        "Be reassuring",
        "Provide time estimates",
        "Use active verbs"
      ],
      "dont": [
        "Leave users in silence",
        "Use vague \"Please wait\"",
        "Make promises you can't keep",
        "Use technical process names"
      ],
      "examples": {
        "good": [
          "Loading your dashboard...",
          "Processing payment... This usually takes 3-5 seconds."
        ],
        "bad": ["Loading...", "Executing database query..."]
      }
    },
    "warnings": {
      "title": "Warning Messages",
      "do": [
        "Clearly state what might go wrong",
        "Explain consequences",
        "Offer alternatives",
        "Use cautious but calm tone"
      ],
      "dont": [
        "Use alarmist language",
        "Be vague about consequences",
        "Bury important warnings",
        "Use all caps or excessive punctuation"
      ],
      "examples": {
        "good": ["Deleting this project will remove all tasks and files. This cannot be undone."],
        "bad": ["WARNING!!! DATA WILL BE LOST!!!"]
      }
    },
    "microcopy": {
      "title": "Microcopy",
      "tooltips": {
        "rules": [
          "Keep under 10 words",
          "Explain what element does, not what it is",
          "Sentence case, no period for fragments"
        ],
        "examples": {
          "good": ["Add team members to this project"],
          "bad": ["This is the add button"]
        }
      },
      "checkboxes": {
        "rules": [
          "Use positive phrasing",
          "Make it clear what happens when selected",
          "Keep scannable"
        ],
        "examples": {
          "good": ["Send me email notifications", "Remember me for 30 days"],
          "bad": ["Do not disable notifications"]
        }
      },
      "links": {
        "rules": [
          "Make links descriptive",
          "Avoid \"click here\" alone",
          "Explain what users will get"
        ],
        "examples": {
          "good": ["View pricing details", "Read the full documentation"],
          "bad": ["Click here", "Learn more"]
        }
      }
    }
  },
  "quickReference": {
    "toneMatrix": [
      { "situation": "User accomplishes goal", "tone": "Celebratory", "energy": "High" },
      { "situation": "First-time experience", "tone": "Encouraging", "energy": "Medium" },
      { "situation": "System processing", "tone": "Reassuring", "energy": "Low" },
      { "situation": "Something breaks", "tone": "Calm & Clear", "energy": "Neutral" },
      { "situation": "Destructive action", "tone": "Cautious", "energy": "Medium" },
      { "situation": "Account/data security", "tone": "Serious", "energy": "Low" }
    ],
    "commonReplacements": {
      "Invalid": "Check your [field name]",
      "Error occurred": "Something went wrong",
      "Forbidden": "You don't have access",
      "Null/Empty": "No [items] yet",
      "Submit": "[Specific action verb]",
      "Click here": "[Descriptive link text]"
    }
  }
}
