{
  "title": "Variant Philosophy",
  "corePrinciple": {
    "statement": "Fewer variants = Consistent UI",
    "explanation": "Every variant is a decision users must make. Reduce decisions, increase clarity.",
    "defaultRule": "Default should be the best choice 90% of the time. If developers need to think about which variant to use, the API is too complex."
  },
  "whenToAdd": {
    "criteria": [
      {
        "rule": "Semantic meaning differs",
        "example": "Success vs error vs warning"
      },
      {
        "rule": "Visual hierarchy requires it",
        "example": "Primary vs secondary action"
      },
      {
        "rule": "Accessibility demands it",
        "example": "High contrast mode treatments"
      },
      {
        "rule": "Business logic requires it",
        "example": "Provisioned vs pending vs failed states"
      },
      {
        "rule": "Design system defines it",
        "example": "Figma shows distinct patterns"
      }
    ],
    "questions": [
      "Does this variant exist in the design system?",
      "Can the use case be solved with existing variants?",
      "Will this variant be used in >3 places?",
      "Does it represent semantic difference, not just cosmetic?"
    ],
    "allCriteriaMustBeTrue": true
  },
  "whenToReject": {
    "signals": [
      "Request is for a one-off visual treatment",
      "Variant name describes appearance, not meaning (e.g., 'blue', 'large-rounded')",
      "Existing variant + prop combination achieves the same result",
      "Only one component instance would use it",
      "Variant adds cognitive load without clear benefit"
    ],
    "autoRejectCriteria": [
      {
        "signal": "Color in name",
        "example": "variant='blue'",
        "reason": "Use semantic name like 'primary'"
      },
      {
        "signal": "Shape in name",
        "example": "variant='rounded'",
        "reason": "Use prop like `radius`"
      },
      {
        "signal": "Combination name",
        "example": "variant='primaryLarge'",
        "reason": "Compose: `variant='primary' size='lg'`"
      },
      {
        "signal": "Single use case",
        "example": "variant='specialHeaderButton'",
        "reason": "Create specialized component instead"
      },
      {
        "signal": "Not in design system",
        "example": "Exists in code only",
        "reason": "Variants must come from design"
      }
    ]
  },
  "semanticVsCosmetic": {
    "statusVariants": {
      "description": "Represent system or data states - always semantic",
      "variants": [
        {
          "name": "success",
          "meaning": "Operation completed, positive outcome"
        },
        {
          "name": "error",
          "meaning": "Operation failed, requires attention"
        },
        {
          "name": "warning",
          "meaning": "Caution needed, potential issue"
        },
        {
          "name": "info",
          "meaning": "Neutral information, no action required"
        },
        {
          "name": "pending",
          "meaning": "In progress, awaiting completion"
        },
        {
          "name": "active",
          "meaning": "Currently selected or in use"
        },
        {
          "name": "disabled",
          "meaning": "Unavailable for interaction"
        }
      ]
    },
    "actionVariants": {
      "description": "Represent visual hierarchy and user intent",
      "variants": [
        {
          "name": "primary",
          "use": "Main action, ONE per view"
        },
        {
          "name": "secondary",
          "use": "Supporting action, complements primary"
        },
        {
          "name": "default",
          "use": "Standard action, no emphasis"
        },
        {
          "name": "ghost",
          "use": "Low emphasis, minimal visual weight"
        },
        {
          "name": "outline",
          "use": "Medium emphasis, bordered style"
        },
        {
          "name": "destructive",
          "use": "Dangerous action, requires confirmation"
        },
        {
          "name": "link",
          "use": "Navigation, text-style button"
        }
      ]
    },
    "cosmeticToPropsConversion": [
      {
        "cosmeticVariant": "rounded vs square",
        "convertTo": "`radius` prop"
      },
      {
        "cosmeticVariant": "bordered vs filled",
        "convertTo": "`bordered` boolean prop"
      },
      {
        "cosmeticVariant": "flat vs elevated",
        "convertTo": "`shadow` prop with semantic levels"
      },
      {
        "cosmeticVariant": "small vs large",
        "convertTo": "`size` prop"
      }
    ]
  },
  "antiPatterns": {
    "signals": [
      {
        "signal": "Color in name",
        "example": "variant='redOutline'",
        "fix": "Use `variant='destructive'`"
      },
      {
        "signal": "7+ variants",
        "example": "10 variant options",
        "fix": "Split into multiple props"
      },
      {
        "signal": "Single-use variant",
        "example": "variant='specialHeaderButton'",
        "fix": "Use props or new component"
      },
      {
        "signal": "Duplicates props",
        "example": "variant='primaryLarge'",
        "fix": "`variant='primary' size='lg'`"
      },
      {
        "signal": "Boolean flags",
        "example": "isPrimary, isDestructive",
        "fix": "Single `variant` prop"
      },
      {
        "signal": "Changes behavior",
        "example": "variant='async' adds logic",
        "fix": "Behavior = props, not variants"
      }
    ],
    "commonMistakes": [
      "Creating variants for edge cases",
      "Duplicating logic that props can handle",
      "Adding variants 'just in case'",
      "Naming variants after colors or visual properties"
    ]
  },
  "implementationRules": {
    "defaultAsBestChoice": {
      "rule": "Default variant should work perfectly without any configuration",
      "examples": [
        "Button with no variant = default (most common use)",
        "Badge with no variant = default (neutral information)",
        "Input with no variant = default (standard input)"
      ]
    },
    "propsOverVariants": {
      "usePropsFor": [
        "Size (sm, md, lg)",
        "Disabled state",
        "Loading state",
        "Icon presence",
        "Full width"
      ],
      "useVariantsFor": ["Semantic meaning", "Visual hierarchy", "State representation"]
    },
    "maxVariantsRule": {
      "threshold": 7,
      "description": "If a component has >7 variants, split",
      "steps": [
        "Identify semantic (keep as variants)",
        "Identify cosmetic (convert to props)",
        "Identify combinations (use compound patterns)"
      ]
    }
  },
  "validationChecklist": [
    "Does variant exist in design system?",
    "Is variant name semantic (meaning, not appearance)?",
    "Will variant be used in 3+ places?",
    "Can this be achieved with existing variants + props?",
    "Does adding this reduce cognitive load?",
    "Is default still the best choice for 90% of uses?"
  ],
  "migrationPath": {
    "tooManyVariants": {
      "threshold": "8+",
      "steps": [
        "Identify semantic -> keep as variants",
        "Identify cosmetic -> convert to props",
        "Identify combinations -> use compound patterns",
        "Deprecate redundant variants"
      ]
    },
    "cosmeticVariantsToRemove": {
      "steps": [
        "Create semantic mapping (`blue` -> `primary`)",
        "Add `@deprecated` JSDoc to old names",
        "Support both during transition",
        "Remove in next major version"
      ]
    }
  },
  "quickReference": [
    {
      "question": "Should this be a variant?",
      "answer": "Only if it's semantic AND used 3+ places"
    },
    {
      "question": "What about visual differences?",
      "answer": "Props, not variants"
    },
    {
      "question": "How many variants is too many?",
      "answer": ">7 on a single prop"
    },
    {
      "question": "Can I combine variants?",
      "answer": "Use separate props: `variant` + `size`"
    },
    {
      "question": "Variant only used once?",
      "answer": "Create specialized component instead"
    }
  ]
}
