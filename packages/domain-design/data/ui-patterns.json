  },
  "spacingGuidelines": {
    "title": "Spacing Guidelines",
    "elements": [
      { "element": "Stats Card", "padding": "24px" },
      { "element": "Compact Card", "padding": "16px" },
      { "element": "Badge", "padding": "10px horizontal, 2px vertical" },
