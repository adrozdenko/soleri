{
  "metadata": {
    "title": "UI Patterns",
    "description": "Consistent visual patterns for admin interfaces and dashboard design. Covers status indicators, priority systems, statistical displays, and activity timelines.",
    "philosophy": "Visual consistency through semantic colors, icons, and predictable patterns."
  },
  "statusBadges": {
    "title": "Status Badge System",
    "description": "Status badges communicate the current state of tasks, items, or workflows. Always use semantic colors with icons for quick visual scanning.",
    "statuses": {
      "pending": {
        "name": "Pending Approval",
        "colorScheme": "warning",
        "semanticColor": "Yellow (Warning)",
        "icon": "Clock",
        "meaning": "Waiting for review or sign-off",
        "cssClasses": "bg-yellow-100 text-yellow-800 border-yellow-200"
      },
      "in-progress": {
        "name": "In Progress",
        "colorScheme": "primary",
        "semanticColor": "Primary",
        "icon": "Loader",
        "iconAnimation": "animate-spin",
        "meaning": "Work is actively being done",
        "cssClasses": "bg-primary-100 text-primary-800 border-primary-200"
      },
      "completed": {
        "name": "Completed",
        "colorScheme": "success",
        "semanticColor": "Green (Success)",
        "icon": "CheckCircle",
        "meaning": "Work has been finished successfully",
        "cssClasses": "bg-green-100 text-green-800 border-green-200"
      },
      "failed": {
        "name": "Failed/Overdue",
        "colorScheme": "error",
        "semanticColor": "Red (Error)",
        "icon": "AlertTriangle",
        "meaning": "Past due date or failed state",
        "cssClasses": "bg-red-100 text-red-800 border-red-200"
      },
      "cancelled": {
        "name": "Closed/Cancelled",
        "colorScheme": "neutral",
        "semanticColor": "Neutral (Gray)",
        "icon": "XCircle",
        "meaning": "Item closed (may or may not be completed)",
        "cssClasses": "bg-gray-100 text-gray-800 border-gray-200"
      },
      "on-hold": {
        "name": "Deferred/On Hold",
        "colorScheme": "neutral-light",
        "semanticColor": "Light Gray",
        "icon": "PauseCircle",
        "meaning": "Postponed for later consideration",
        "cssClasses": "bg-gray-50 text-gray-600 border-gray-100"
      },
      "scheduled": {
        "name": "Assigned/Scheduled",
        "colorScheme": "info",
        "semanticColor": "Blue (Info)",
        "icon": "UserCheck",
        "meaning": "Task has been assigned to someone",
        "cssClasses": "bg-blue-100 text-blue-800 border-blue-200"
      },
      "draft": {
        "name": "Draft",
        "colorScheme": "neutral-light",
        "semanticColor": "Light Neutral",
        "icon": "FileEdit",
        "meaning": "Not yet published or finalized",
        "cssClasses": "bg-gray-50 text-gray-500 border-gray-100"
      },
      "blocked": {
        "name": "Blocked",
        "colorScheme": "error-light",
        "semanticColor": "Light Error",
        "icon": "Ban",
        "meaning": "Cannot proceed due to blocker",
        "cssClasses": "bg-red-50 text-red-600 border-red-100"
      }
    },
    "styling": {
      "baseStructure": "Inline flex container with icon and text",
      "shape": "Rounded pill (fully rounded corners)",
      "typography": "Extra small (xs), medium weight",
      "spacing": {
        "horizontal": "10px",
        "vertical": "2px"
      },
      "border": "Subtle border matching the color scheme"
    },
    "guidelines": [
      "Always use semantic status colors",
      "Include an icon for quick scanning",
      "Keep labels concise (1-2 words)",
      "Use consistent badge sizing across tables and lists"
    ],
    "colorMapping": {
      "assigned": "Info (Blue)",
      "in-progress": "Primary",
      "pending": "Warning (Yellow)",
      "completed": "Success (Green)",
      "closed": "Neutral (Gray)",
      "deferred": "Light Neutral",
      "overdue": "Error (Red)",
      "blocked": "Light Error"
    }
  },
  "priorityBadges": {
    "title": "Priority Badge System",
    "description": "Priority indicators help users quickly identify urgency and importance of tasks.",
    "priorities": {
      "critical": {
        "name": "Urgent/Critical",
        "colorScheme": "error",
        "semanticColor": "Red (Error)",
        "icon": "AlertOctagon",
        "dotColor": "red",
        "animation": "pulse",
        "cssClasses": "bg-red-100 text-red-800 border-red-200",
        "dotCssClasses": "bg-red-500 animate-pulse"
      },
      "high": {
        "name": "High",
        "colorScheme": "warning",
        "semanticColor": "Yellow (Warning)",
        "icon": "ArrowUp",
        "dotColor": "yellow",
        "animation": null,
        "cssClasses": "bg-yellow-100 text-yellow-800 border-yellow-200",
        "dotCssClasses": "bg-yellow-500"
      },
      "medium": {
        "name": "Medium",
        "colorScheme": "info",
        "semanticColor": "Blue (Info)",
        "icon": "Minus",
        "dotColor": "blue",
        "animation": null,
        "cssClasses": "bg-blue-100 text-blue-800 border-blue-200",
        "dotCssClasses": "bg-blue-500"
      },
      "low": {
        "name": "Low",
        "colorScheme": "neutral",
        "semanticColor": "Gray (Neutral)",
        "icon": "ArrowDown",
        "dotColor": "gray",
        "animation": null,
        "cssClasses": "bg-gray-100 text-gray-800 border-gray-200",
        "dotCssClasses": "bg-gray-400"
      }
    },
    "displayVariants": [
      {
        "variant": "Badge",
        "description": "Full badge with background and border",
        "useCase": "Primary display"
      },
      {
        "variant": "Dot",
        "description": "Simple colored dot indicator",
        "useCase": "Compact lists"
      },
      {
        "variant": "Icon",
        "description": "Icon only with color",
        "useCase": "Space-constrained views"
      },
      {
        "variant": "Text",
        "description": "Colored text label only",
        "useCase": "Inline references"
      }
    ],
    "dotIndicator": {
      "size": "8px",
      "shape": "Perfect circle",
      "animation": "Pulse effect for urgent items only"
    },
    "colorMapping": {
      "low": "Neutral (Gray)",
      "medium": "Info (Blue)",
      "high": "Warning (Yellow)",
      "urgent": "Error (Red)"
    }
  },
  "statsCards": {
    "title": "Stats Card Pattern",
    "description": "Dashboard statistics cards display key metrics with visual hierarchy.",
    "anatomy": [
      {
        "element": "Title",
        "typography": "Small, medium weight, muted color",
        "purpose": "Metric name"
      },
      {
        "element": "Value",
        "typography": "2XL, semibold, primary color",
        "purpose": "Primary metric value"
      },
      {
        "element": "Subtitle",
        "typography": "Extra small, muted",
        "purpose": "Additional context"
      },
      {
        "element": "Trend",
        "typography": "Extra small, colored by direction",
        "purpose": "Change indicator"
      },
      {
        "element": "Icon",
        "typography": "Large, in colored container",
        "purpose": "Visual identifier"
      }
    ],
    "trendIndicators": [
      {
        "direction": "Positive",
        "color": "Green (Success)",
        "icon": "TrendingUp",
        "format": "+12.5%"
      },
      {
        "direction": "Negative",
        "color": "Red (Error)",
        "icon": "TrendingDown",
        "format": "-8.2%"
      },
      {
        "direction": "Neutral",
        "color": "Gray",
        "icon": "Minus",
        "format": "0%"
      }
    ],
    "layoutVariants": [
      {
        "layout": "Horizontal",
        "description": "Icon left, content right",
        "bestFor": "Default card layout"
      },
      {
        "layout": "Vertical",
        "description": "Icon top, content below",
        "bestFor": "Grid of equal-width cards"
      },
      {
        "layout": "Compact",
        "description": "Minimal spacing, smaller text",
        "bestFor": "Sidebar or dense dashboards"
      }
    ],
    "responsiveGrid": {
      "mobile": { "columns": 1, "gap": "16px" },
      "tablet": { "columns": 2, "gap": "16px" },
      "desktop": { "columns": 4, "gap": "24px" }
    },
    "spacing": {
      "default": "24px padding",
      "compact": "16px padding"
    }
  },
  "timelines": {
    "title": "Timeline Activity Pattern",
    "description": "Activity timelines display chronological events and actions.",
    "anatomy": [
      {
        "element": "Container",
        "description": "Relative positioned wrapper"
      },
      {
        "element": "Connector",
        "description": "Vertical line connecting items"
      },
      {
        "element": "Marker",
        "description": "Icon or dot at connection point"
      },
      {
        "element": "Content",
        "description": "Actor, action, timestamp, detail"
      }
    ],
    "contentStructure": [
      {
        "part": "Actor",
        "typography": "Small, medium weight",
        "example": "John Smith"
      },
      {
        "part": "Action",
        "typography": "Small, muted",
        "example": "updated the status"
      },
      {
        "part": "Timestamp",
        "typography": "Extra small, light gray",
        "example": "2 hours ago"
      },
      {
        "part": "Detail",
        "typography": "Small, in subtle container",
        "example": "Additional context or quote"
      }
    ],
    "eventTypes": [
      {
        "event": "Create",
        "icon": "Plus",
        "colorScheme": "Green (Success)"
      },
      {
        "event": "Update",
        "icon": "Pencil",
        "colorScheme": "Blue (Info)"
      },
      {
        "event": "Delete",
        "icon": "Trash",
        "colorScheme": "Red (Error)"
      },
      {
        "event": "Comment",
        "icon": "MessageSquare",
        "colorScheme": "Primary"
      },
      {
        "event": "Status Change",
        "icon": "RefreshCw",
        "colorScheme": "Yellow (Warning)"
      },
      {
        "event": "Assignment",
        "icon": "UserPlus",
        "colorScheme": "Blue (Info)"
      }
    ],
    "markerStyles": {
      "defaultDot": {
        "size": "12px",
        "shape": "circle",
        "color": "primary"
      },
      "withIcon": {
        "size": "32px",
        "shape": "circle with centered icon"
      }
    },
    "spacing": {
      "leftMargin": "32px (for marker)",
      "bottomMargin": "32px"
    }
  },
  "adminDashboard": {
    "title": "Admin Dashboard Patterns",
    "dueDateIndicators": {
      "title": "Due Date Indicators",
      "description": "Visual indicators for due date status help users manage deadlines effectively.",
      "states": [
        {
          "state": "Overdue",
          "condition": "Date < Today",
          "color": "Red (Error)",
          "icon": "AlertTriangle",
          "displayFormat": "X days overdue"
        },
        {
          "state": "Due Today",
          "condition": "Date = Today",
          "color": "Yellow (Warning)",
          "icon": "Clock",
          "displayFormat": "Due Today (emphasized)"
        },
        {
          "state": "Due Soon",
          "condition": "Date <= Today + 3 days",
          "color": "Light Yellow",
          "icon": "Calendar",
          "displayFormat": "Due in X days"
        },
        {
          "state": "Future",
          "condition": "Date > Today + 3 days",
          "color": "Neutral Gray",
          "icon": "CalendarDays",
          "displayFormat": "Due MMM DD"
        },
        {
          "state": "Completed",
          "condition": "Status = Completed",
          "color": "Green (strikethrough)",
          "icon": "CheckCircle",
          "displayFormat": "Completed MMM DD"
        },
        {
          "state": "No Due Date",
          "condition": "Date = null",
          "color": "Light Gray",
          "icon": "Calendar",
          "displayFormat": "No due date"
        }
      ],
      "formattingOptions": [
        { "type": "Relative", "example": "2 days ago, in 3 days" },
        { "type": "Absolute", "example": "Jan 15, 2024" },
        { "type": "Combined", "example": "Jan 15 (2 days ago)" }
      ]
    },
    "dataTablePatterns": {
      "title": "Data Table Patterns",
      "rowEmphasis": [
        { "priority": "Urgent", "borderStyle": "4px solid red" },
        { "priority": "High", "borderStyle": "4px solid yellow" },
        { "priority": "Normal", "borderStyle": "4px transparent" },
        { "priority": "Completed", "borderStyle": "4px solid green" }
      ],
      "rowHighlighting": [
        { "state": "Selected", "background": "Primary 5% opacity" },
        { "state": "Hover", "background": "Surface color" },
        { "state": "New", "background": "Info 5% + pulse animation" },
        { "state": "Error", "background": "Error 5% opacity" }
      ],
      "cellTypes": [
        {
          "type": "Primary",
          "styling": "Medium weight, dark",
          "useFor": "Main identifier (name, title)"
        },
        { "type": "Secondary", "styling": "Small, muted", "useFor": "Supporting information" },
        { "type": "Badge", "styling": "Inline flex with gap", "useFor": "Status, priority, tags" },
        {
          "type": "Action",
          "styling": "Right-aligned flex",
          "useFor": "Row actions (edit, delete)"
        },
        { "type": "Truncate", "styling": "Max width with ellipsis", "useFor": "Long text fields" }
      ],
      "sortingIndicators": [
        { "state": "Sortable (unsorted)", "icon": "ArrowUpDown (subtle)" },
        { "state": "Ascending", "icon": "ArrowUp" },
        { "state": "Descending", "icon": "ArrowDown" }
      ]
    },
    "filterNavigation": {
      "title": "Filter and Navigation Patterns",
      "filterBarLayout": "[ Search Input (flexible) ] [ Status Filter ] [ Priority Filter ] [ Date Range ] [ Clear ]",
      "tabNavigationWithCounts": [
        { "tab": "All", "badgeStyle": "Secondary, showing total count" },
        { "tab": "Active", "badgeStyle": "Secondary, showing active count" },
        { "tab": "Pending", "badgeStyle": "Secondary, showing pending count" },
        { "tab": "Completed", "badgeStyle": "Secondary, showing completed count" }
      ],
      "filterChips": {
        "style": "Badge style with secondary variant",
        "features": ["Include X button for removal", "Wrap to multiple lines as needed"]
      }
    },
    "responsiveDesign": {
      "title": "Responsive Design Strategy",
      "breakpoints": [
        {
          "viewport": "Mobile",
          "width": "< 640px",
          "adaptations": "Stack layouts, card lists instead of tables, collapsed filters"
        },
        {
          "viewport": "Tablet",
          "width": "640-1024px",
          "adaptations": "2-column grids, reduced table columns, icon-only sidebar"
        },
        {
          "viewport": "Desktop",
          "width": ">= 1024px",
          "adaptations": "Full features, 4-column stats, expanded sidebar"
        }
      ],
      "mobileTransformations": [
        { "desktop": "Data table", "mobile": "Card list" },
        { "desktop": "Filter bar", "mobile": "Filter sheet (slide-up)" },
        { "desktop": "Full sidebar", "mobile": "Bottom navigation (5 max items)" },
        { "desktop": "Inline actions", "mobile": "Floating action button" }
      ],
      "mobileCardStructure": [
        "Header: Primary info + status badge",
        "Body: Key details in 2-column grid",
        "Footer: Action buttons"
      ],
      "responsiveUtilityClasses": [
        { "purpose": "Hide on mobile", "pattern": "Hidden by default, visible at sm breakpoint" },
        {
          "purpose": "Show only on mobile",
          "pattern": "Visible by default, hidden at sm breakpoint"
        },
        {
          "purpose": "Full width on mobile",
          "pattern": "Full width default, auto at sm breakpoint"
        },
        {
          "purpose": "Stack on mobile",
          "pattern": "Column direction default, row at sm breakpoint"
        }
      ]
    },
    "accessibility": {
      "title": "Accessibility Requirements",
      "statusCommunication": [
        "Never rely on color alone for status",
        "Include icon + text label",
        "Use aria-label for icon-only indicators",
        "Announce status changes to screen readers"
      ],
      "tableAccessibility": [
        "Use semantic table elements",
        "Include caption describing table purpose",
        "Use scope='col' for header cells",
        "Provide aria-sort for sortable columns",
        "Announce filter results to screen readers"
      ],
      "focusManagement": [
        "Visible focus indicators on all interactive elements",
        "Logical tab order: filters -> table -> pagination",
        "Skip links for long tables",
        "Focus trap in modals and sheets"
      ]
    },
    "cardGridPatterns": [
      { "layoutType": "Stats", "columns": "1 / 2 / 4" },
      { "layoutType": "Widgets", "columns": "1 / 1 / 3" },
      { "layoutType": "Equal Cards", "columns": "1 / 2 / 3-4" },
      { "layoutType": "Config Cards", "columns": "1 / 1 / 2" }
    ]
  },
