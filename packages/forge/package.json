{
  "name": "@soleri/forge",
  "version": "9.12.0",
  "description": "Scaffold AI agents that learn, remember, and grow with you.",
  "keywords": [
    "agent",
    "ai",
    "forge",
    "generator",
    "knowledge",
    "mcp",
    "scaffold",
    "soleri",
    "vault"
  ],
  "homepage": "https://soleri.dev",
  "license": "Apache-2.0",
  "author": "adrozdenko",
  "repository": {
    "type": "git",
    "url": "https://github.com/adrozdenko/soleri.git",
    "directory": "packages/forge"
  },
  "bin": {
    "soleri-forge": "dist/index.js"
  },
  "type": "module",
  "main": "dist/index.js",
  "exports": {
    ".": "./dist/index.js",
    "./lib": {
      "types": "./dist/lib.d.ts",
      "import": "./dist/lib.js"
    },
    "./templates/extensions": {
      "types": "./dist/templates/extensions.d.ts",
      "import": "./dist/templates/extensions.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc && rm -rf dist/skills && cp -r src/skills dist/skills",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "@soleri/core": "^9.0.0",
    "yaml": "^2.8.2",
    "zod": "^3.24.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
