{
  "name": "@soleri/cli",
  "version": "9.9.0",
  "description": "Developer CLI for creating and managing Soleri AI agents.",
  "keywords": [
    "agent",
    "ai",
    "cli",
    "mcp",
    "scaffold",
    "soleri"
  ],
  "homepage": "https://soleri.dev",
  "license": "Apache-2.0",
  "author": "adrozdenko",
  "repository": {
    "type": "git",
    "url": "https://github.com/adrozdenko/soleri.git",
    "directory": "packages/cli"
  },
  "bin": {
    "soleri": "dist/main.js"
  },
  "type": "module",
  "main": "dist/main.js",
  "exports": {
    ".": "./dist/main.js",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "tsx src/main.ts",
    "build": "tsc && cp -r src/hook-packs dist/",
    "start": "node dist/main.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@clack/prompts": "^1.0.0",
    "@soleri/core": "^9.0.0",
    "@soleri/forge": "^9.0.0",
    "commander": "^13.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
