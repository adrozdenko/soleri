{
  "name": "@soleri/core",
  "version": "9.16.5",
  "description": "Shared engine for Soleri agents — vault, brain, planner, LLM utilities, and facade infrastructure.",
  "keywords": [
    "agent",
    "ai",
    "brain",
    "core",
    "llm",
    "mcp",
    "planner",
    "soleri",
    "vault"
  ],
  "homepage": "https://soleri.dev",
  "license": "Apache-2.0",
  "author": "adrozdenko",
  "repository": {
    "type": "git",
    "url": "https://github.com/adrozdenko/soleri.git",
    "directory": "packages/core"
  },
  "bin": {
    "soleri-engine": "dist/engine/bin/soleri-engine.js"
  },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./module-manifest": {
      "types": "./dist/engine/module-manifest.d.ts",
      "import": "./dist/engine/module-manifest.js"
    },
    "./personas": {
      "types": "./dist/persona/defaults.d.ts",
      "import": "./dist/persona/defaults.js"
    },
    "./skills/validate-skills": {
      "types": "./dist/skills/validate-skills.d.ts",
      "import": "./dist/skills/validate-skills.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc && rm -rf dist/knowledge-packs && cp -r ../../knowledge-packs dist/knowledge-packs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "yaml": "^2.7.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/pdf-parse": "^1.1.5",
    "@vitest/coverage-v8": "^4.0.18"
  },
  "peerDependencies": {
    "@anthropic-ai/sdk": ">=0.30.0",
    "@modelcontextprotocol/sdk": "^1.28.0"
  },
  "peerDependenciesMeta": {
    "@anthropic-ai/sdk": {
      "optional": true
    }
  },
  "optionalDependencies": {
    "better-sqlite3": ">=11.0.0",
    "pdf-parse": "^1.1.4"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
