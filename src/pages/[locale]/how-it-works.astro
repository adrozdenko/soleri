---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CTA from '../../components/CTA.astro';
import { t } from '../../i18n/ui';
import { locales } from '../../i18n/types';
import type { Locale } from '../../i18n/types';
import { howItWorksContent } from '../../i18n/pages/how-it-works';
import '../../styles/how-it-works.css';

export function getStaticPaths() {
  return locales.map(locale => ({ params: { locale }, props: { locale } }));
}

const { locale } = Astro.props as { locale: Locale };
const c = howItWorksContent(locale);
---
<BaseLayout
  title={c.title}
  description={c.description}
  lang={locale}
  locale={locale}
>
  <!-- HERO -->
  <section class="page-hero">
    <div class="soleri-mark mark-hero"></div>
    <p class="eyebrow">{c.eyebrow}</p>
    <h1>{c.heroTitle}</h1>
    <p class="hero-subtitle" set:html={c.heroSubtitle} />
  </section>

  <!-- SECTIONS -->
  {c.sections.map((s, i) => (
    <>
      {i > 0 && <div class="soleri-mark mark-section"></div>}
      <section class="deep-section">
        <div class={`deep-grid${i % 2 === 1 ? ' reverse' : ''}`}>
          <div class="deep-content">
            <h2 class="how-title">{s.title}</h2>
            <p class="how-subtitle">{s.subtitle}</p>
            <p>{s.text}</p>
          </div>
          <div>
            <div class="feature-code" set:html={s.code} />
            {s.barChart && (
              <div class="bar-chart">
                {s.barChart.map(b => (
                  <div class="bar-row">
                    <span class="bar-label">{b.label}</span>
                    <div class="bar-track"><div class={`bar-fill ${b.color}`} style={`width:${b.strength}%`}></div></div>
                    <span class="bar-value">{b.strength}</span>
                  </div>
                ))}
              </div>
            )}
          </div>
        </div>
      </section>
    </>
  ))}

  <CTA locale={locale} />
</BaseLayout>
