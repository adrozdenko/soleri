---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CTA from '../../components/CTA.astro';
import { t } from '../../i18n/ui';
import { locales } from '../../i18n/types';
import type { Locale } from '../../i18n/types';
import { gettingStartedContent } from '../../i18n/pages/getting-started';
import '../../styles/getting-started.css';

export function getStaticPaths() {
  return locales.map(locale => ({ params: { locale }, props: { locale } }));
}

const { locale } = Astro.props as { locale: Locale };
const c = gettingStartedContent(locale);

// Group principles by category (hint field)
const principleCategories: Array<{ cat: string; opts: Array<{ name: string; hint: string }> }> = [];
const catMap = new Map<string, Array<{ name: string; hint: string }>>();
for (const opt of c.wizardRef.principles.options) {
  const cat = opt.hint;
  if (!catMap.has(cat)) {
    catMap.set(cat, []);
    principleCategories.push({ cat, opts: catMap.get(cat)! });
  }
  catMap.get(cat)!.push(opt);
}
---
<BaseLayout
  title={c.title}
  description={c.description}
  lang={locale}
  locale={locale}
>
  <!-- PAGE HERO -->
  <section class="page-hero">
    <div class="soleri-mark mark-hero"></div>
    <p class="eyebrow">{c.eyebrow}</p>
    <h1>{c.heroTitle}</h1>
    <p class="hero-subtitle">{c.heroSubtitle}</p>
  </section>

  <!-- STEPS -->
  <div class="steps">
    {c.steps.map((step, i) => (
      <div class="step">
        <div class="step-number">{i + 1}</div>
        <div class="step-content">
          <h3>{step.title}</h3>
          <p>{step.text}</p>
          {step.isInstallCmd ? (
            <div class="code-block">
              <div class="install-cmd" set:html={step.code} />
              <button class="copy-btn" type="button" aria-label="Copy command">
                <svg class="copy-icon" viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
                <svg class="check-icon" viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              </button>
            </div>
          ) : (
            <div class="code-block">
              <div class="feature-code" set:html={step.code} />
              <button class="copy-btn" type="button" aria-label="Copy command">
                <svg class="copy-icon" viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
                <svg class="check-icon" viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              </button>
            </div>
          )}
        </div>
      </div>
    ))}
  </div>

  <div class="soleri-mark mark-section"></div>

  <!-- WIZARD REFERENCE -->
  <section class="section spacious wizard-ref">
    <div class="section-header">
      <h2 class="section-title">{c.wizardRef.sectionTitle}</h2>
      <p class="section-subtitle">{c.wizardRef.sectionSubtitle}</p>
    </div>

    <!-- Wizard flow bar -->
    <div class="wizard-flow">
      {[c.wizardRef.archetypes, c.wizardRef.domains, c.wizardRef.principles, c.wizardRef.skills, c.wizardRef.tones].map((section, i) => (
        <div class="wizard-flow-step">
          <span class="wizard-flow-num">{i + 1}</span>
          <span class="wizard-flow-label">{section.title}</span>
        </div>
      ))}
    </div>

    <!-- Step 1: Archetypes — primary choice -->
    <div class="ref-group ref-group-primary">
      <div class="ref-group-header">
        <span class="ref-step-badge">{c.wizardRef.stepLabel} 1</span>
        <h3 class="ref-group-title">{c.wizardRef.archetypes.title}</h3>
      </div>
      <p class="ref-group-desc">{c.wizardRef.archetypes.description}</p>
      <div class="ref-options ref-options-archetypes">
        {c.wizardRef.archetypes.options.map((opt) => (
          <div class="ref-option ref-option-archetype">
            <span class="ref-option-name">{opt.name}</span>
            <span class="ref-option-hint">{opt.hint}</span>
          </div>
        ))}
      </div>
      <p class="ref-prefills-note">{c.wizardRef.prefillsNote}</p>
    </div>

    <!-- Step 2: Domains -->
    <div class="ref-group">
      <div class="ref-group-header">
        <span class="ref-step-badge">{c.wizardRef.stepLabel} 2</span>
        <h3 class="ref-group-title">{c.wizardRef.domains.title}</h3>
      </div>
      <p class="ref-group-desc">{c.wizardRef.domains.description}</p>
      <div class="ref-options">
        {c.wizardRef.domains.options.map((opt) => (
          <div class="ref-option">
            <span class="ref-option-name">{opt.name}</span>
            <span class="ref-option-hint">{opt.hint}</span>
          </div>
        ))}
      </div>
    </div>

    <!-- Step 3: Principles — grouped by category -->
    <div class="ref-group">
      <div class="ref-group-header">
        <span class="ref-step-badge">{c.wizardRef.stepLabel} 3</span>
        <h3 class="ref-group-title">{c.wizardRef.principles.title}</h3>
      </div>
      <p class="ref-group-desc">{c.wizardRef.principles.description}</p>
      {principleCategories.map(({ cat, opts }) => (
        <div class="ref-category">
          <span class="ref-category-label">{cat}</span>
          <div class="ref-options">
            {opts.map((opt) => (
              <div class="ref-option">
                <span class="ref-option-name">{opt.name}</span>
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>

    <!-- Step 4: Skills -->
    <div class="ref-group">
      <div class="ref-group-header">
        <span class="ref-step-badge">{c.wizardRef.stepLabel} 4</span>
        <h3 class="ref-group-title">{c.wizardRef.skills.title}</h3>
      </div>
      <p class="ref-group-desc">{c.wizardRef.skills.description}</p>
      <div class="ref-options">
        {c.wizardRef.skills.options.map((opt) => (
          <div class="ref-option">
            <span class="ref-option-name">{opt.name}</span>
            <span class="ref-option-hint">{opt.hint}</span>
          </div>
        ))}
      </div>
      <p class="ref-core-note">{c.wizardRef.coreSkillsNote}</p>
    </div>

    <!-- Step 5: Tones -->
    <div class="ref-group">
      <div class="ref-group-header">
        <span class="ref-step-badge">{c.wizardRef.stepLabel} 5</span>
        <h3 class="ref-group-title">{c.wizardRef.tones.title}</h3>
      </div>
      <p class="ref-group-desc">{c.wizardRef.tones.description}</p>
      <div class="ref-options">
        {c.wizardRef.tones.options.map((opt) => (
          <div class="ref-option">
            <span class="ref-option-name">{opt.name}</span>
            <span class="ref-option-hint">{opt.hint}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <div class="soleri-mark mark-section"></div>

  <!-- NEXT STEPS -->
  <section class="section spacious">
    <div class="section-header">
      <h2 class="section-title">{c.nextTitle}</h2>
    </div>
    <div class="next-links">
      {c.nextLinks.map(link => (
        <a class="next-link" href={link.href}>
          <span class="next-link-title">{link.title}</span>
          <span class="next-link-desc" set:html={link.desc} />
        </a>
      ))}
    </div>
  </section>

  <div class="soleri-mark mark-section"></div>

  <CTA locale={locale} />
</BaseLayout>

<script>
  document.querySelectorAll('.copy-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const block = btn.closest('.code-block');
      if (!block) return;
      const codeEl = block.querySelector('.install-cmd, .feature-code');
      if (!codeEl) return;
      const text = codeEl.textContent
        ?.replace(/^\s*\$\s*/gm, '')
        .replace(/\n{3,}/g, '\n\n')
        .trim() ?? '';
      navigator.clipboard.writeText(text).then(() => {
        btn.classList.add('copied');
        setTimeout(() => btn.classList.remove('copied'), 2000);
      });
    });
  });
</script>
