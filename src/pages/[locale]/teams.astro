---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CTA from '../../components/CTA.astro';
import { t } from '../../i18n/ui';
import { locales } from '../../i18n/types';
import type { Locale } from '../../i18n/types';
import { teamsContent } from '../../i18n/pages/teams';
import '../../styles/teams.css';

export function getStaticPaths() {
  return locales.map(locale => ({ params: { locale }, props: { locale } }));
}

const { locale } = Astro.props as { locale: Locale };
const c = teamsContent(locale);
---
<BaseLayout
  title={c.meta.title}
  description={c.meta.description}
  lang={locale}
  locale={locale}
>
  <!-- HERO -->
  <section class="page-hero">
    <div class="soleri-mark mark-hero"></div>
    <p class="eyebrow">{c.hero.eyebrow}</p>
    <h1>{c.hero.title}</h1>
    <p class="hero-subtitle">{c.hero.subtitle}</p>
  </section>

  <!-- SECTIONS -->
  {c.sections.map((s, i) => (
    <>
      {i > 0 && <div class="soleri-mark mark-section"></div>}
      <section class="deep-section">
        <div class="deep-grid">
          <div class="deep-content">
            <h2 class="how-title">{s.title}</h2>
            <p class="how-subtitle">{s.subtitle}</p>
            <p>{s.text}</p>
          </div>
          <div>
            <div class="feature-code" set:html={s.code} />
          </div>
        </div>
      </section>
    </>
  ))}

  <CTA locale={locale} />
</BaseLayout>
