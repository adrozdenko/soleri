{
  "name": "soleri-monorepo",
  "version": "9.18.2",
  "private": true,
  "description": "Open-source second brain builder. Persistent memory, structured knowledge, and intelligence that compounds with every session.",
  "keywords": [
    "ai",
    "assistant",
    "brain",
    "claude",
    "framework",
    "knowledge",
    "learning",
    "mcp",
    "memory",
    "personas",
    "vault"
  ],
  "homepage": "https://soleri.dev",
  "license": "Apache-2.0",
  "author": "adrozdenko",
  "repository": {
    "type": "git",
    "url": "https://github.com/adrozdenko/soleri.git"
  },
  "workspaces": [
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "build:web": "astro build",
    "dev:web": "astro dev",
    "preview:web": "astro preview",
    "test": "npm run test --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "dev": "npm run dev --workspace=@soleri/forge",
    "dev:forge": "tsx packages/forge/src/index.ts",
    "lint": "oxlint packages/",
    "lint:fix": "oxlint packages/ --fix",
    "format": "oxfmt --config .oxfmtrc.jsonc packages/",
    "format:check": "oxfmt --check --config .oxfmtrc.jsonc packages/",
    "lint:md": "markdownlint-cli2",
    "lint:spell": "cspell --no-progress",
    "secrets:check": "secretlint \"packages/*/src/**\"",
    "deadcode:knip": "knip --exclude exports --exclude types --exclude duplicates --exclude unlisted --exclude binaries",
    "deadcode:ts-prune": "ts-prune",
    "test:e2e": "vitest run --config e2e/vitest.config.ts --dir e2e && vitest run --config e2e/vitest.heavy.config.ts",
    "validate-skills": "tsx packages/core/src/skills/validate-skill-docs.ts",
    "prepare": "husky"
  },
  "dependencies": {
    "@astrojs/starlight": "^0.37.6",
    "@modelcontextprotocol/sdk": "^1.28.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@astrojs/react": "^4.4.2",
    "@astrojs/sitemap": "^3.7.0",
    "@astrojs/tailwind": "^6.0.2",
    "@secretlint/secretlint-rule-preset-recommend": "^11.3.1",
    "@types/node": "^22.13.4",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "astro": "^5.18.0",
    "cspell": "^9.7.0",
    "husky": "^9.1.7",
    "knip": "^5.85.0",
    "lint-staged": "^16.3.2",
    "markdownlint-cli2": "^0.21.0",
    "oxfmt": "^0.35.0",
    "oxlint": "^1.51.0",
    "secretlint": "^11.3.1",
    "tailwindcss": "^3.4.17",
    "ts-prune": "^0.10.3",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  },
  "lint-staged": {
    "packages/*/src/**/*.ts": [
      "oxfmt --config .oxfmtrc.jsonc",
      "oxlint --fix",
      "secretlint"
    ],
    "packages/*/package.json": [
      "oxfmt --config .oxfmtrc.jsonc"
    ],
    "package.json": [
      "oxfmt --config .oxfmtrc.jsonc"
    ],
    "*.md": [
      "markdownlint-cli2 --no-globs",
      "cspell --no-must-find-files --no-progress"
    ]
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
